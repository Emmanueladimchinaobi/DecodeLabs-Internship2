* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: Arial, sans-serif;
    min-height: 100vh;
    padding: 20px;
}

/* GRID = HOUSE */
.container {
    display: grid;
    grid-template-columns: 250px 1fr;
    grid-template-rows: 100px 1fr 100px;
    gap: 10px;
    min-height: 100vh;
    

    grid-template-areas:
        "header header"
        "sidebar main"
        "footer footer";
}

.header {
    grid-area: header;
    border: 4px solid #0d4d78;
    color: pink;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    background-color: black;
    
   
    
}

.sidebar {
    grid-area: sidebar;
    border: 4px solid #0d4d78;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    color: pink;
    background-color: black;
}

.main {
    grid-area: main;
    border: 4px solid #0d4d78;
    padding: 30px;
    background-color: black;
}

.footer {
    grid-area: footer;
    border: 4px solid #0d4d78;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.3rem;
    gap:8px;
    background-color: black; 
}
.icons{
    color: pink;
}

/* FLEXBOX = FURNITURE */
.cards {
    display: flex;
    justify-content: center;
    gap: 30px;
    flex-wrap: wrap;
}

.card {
    width: 220px;
    border: 4px solid white;
    padding: 15px;
    display: flex;
    flex-direction: column;
    gap: 15px;
    background-color: pink;
}

